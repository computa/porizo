# ==============================================
# Porizo Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Database Configuration
# ==============================================
# DB_PROVIDER: "postgres" (recommended) or "sqlite" (legacy)
# Always use postgres for dev/prod parity - prevents SQL dialect bugs
DB_PROVIDER=postgres

# PostgreSQL connection (when DB_PROVIDER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=porizo
POSTGRES_USER=porizo
POSTGRES_PASSWORD=dev_password

# Full connection URL (alternative to individual settings)
# DATABASE_URL=postgresql://porizo:dev_password@localhost:5432/porizo

# ==============================================
# Storage Configuration (Phase 2)
# ==============================================
# STORAGE_PROVIDER: "local" (default) or "s3"
STORAGE_PROVIDER=local

# AWS S3 (when STORAGE_PROVIDER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=porizo-storage

# LocalStack endpoint for local S3 development
# AWS_ENDPOINT=http://localhost:4566

# ==============================================
# Provider API Keys
# ==============================================
# Replicate API (for voice embedding and Suno music)
REPLICATE_API_TOKEN=your_replicate_token

# Replicate RVC model version
REPLICATE_MODEL_VERSION=0a9c7c558af4c0f20667c1bd1260ce32a2879944a0b9e44e1398660c077b1550

# Suno API (music generation)
SUNO_API_KEY=your_suno_api_key
SUNO_BASE_URL=https://api.sunoapi.org
MUSIC_PROVIDER=suno

# Seed-VC (voice conversion via Gradio)
SEED_VC_BASE_URL=http://localhost:7860

# Hugging Face token (for Seed-VC model access)
HF_TOKEN=your_hf_token

# LLM Providers (for lyrics and moderation)
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# ==============================================
# Apple Sign In (client + server validation)
# ==============================================
# Client IDs accepted for Apple ID token verification
APPLE_CLIENT_ID=com.porizo.app
# Optional: comma-separated list of valid client IDs
# APPLE_CLIENT_IDS=com.porizo.app,com.porizo.web

# Server-side Apple Sign-In token exchange (authorization code / refresh token)
APPLE_SIGNIN_TEAM_ID=your_apple_team_id
APPLE_SIGNIN_KEY_ID=your_apple_key_id
APPLE_SIGNIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ==============================================
# Google Sign-In (OAuth + token verification)
# ==============================================
# OAuth client ID used for token verification
GOOGLE_CLIENT_ID=your_google_client_id
# Optional client secret (required if you use a web client)
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Redirect URI used for OAuth code exchange
GOOGLE_REDIRECT_URI=porizo-oauth://auth/google

# ==============================================
# Facebook Login (OAuth + token verification)
# ==============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=porizo-oauth://auth/facebook

# ==============================================
# Voice Mode Configuration
# ==============================================
# DEFAULT_VOICE_MODE: "ai_voice" or "personalized"
# ai_voice: Uses Replicate RVC with pre-trained models
# personalized: Uses Seed-VC with user's enrolled voice
DEFAULT_VOICE_MODE=ai_voice

# ==============================================
# Feature Flags
# ==============================================
# LIVE_PROVIDERS: true to use real APIs, false to mock
LIVE_PROVIDERS=true
# STORY_ENGINE_DEFAULT: default story runtime for /story/start when client does not specify engine_version
# Supported: v2, v3
STORY_ENGINE_DEFAULT=v3
# ENABLE_V3_ORCHESTRATION_ROUTES: exposes /story/v3/orchestration/* experimental endpoints
ENABLE_V3_ORCHESTRATION_ROUTES=false
# ORCHESTRATION_EXECUTOR_MODE: "local" or "external"
ORCHESTRATION_EXECUTOR_MODE=local
# JSON array command for external executor runtime (required when mode=external)
# Example: ["node","scripts/orchestration-executor.js"]
ORCHESTRATION_EXTERNAL_COMMAND_JSON=
# Timeout for external executor process in ms
ORCHESTRATION_EXTERNAL_TIMEOUT_MS=120000

# ==============================================
# Server Configuration
# ==============================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
ADMIN_SECRET_KEY=your-secret-admin-key

# Optional iOS beta install URL used by /download when channel=testflight
# Example: https://testflight.apple.com/join/abc12345
IOS_TESTFLIGHT_URL=
