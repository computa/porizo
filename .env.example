# ==============================================
# Porizo Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# ==============================================
# Database Configuration
# ==============================================
# DB_PROVIDER: "sqlite" (default) or "postgres"
DB_PROVIDER=sqlite

# PostgreSQL connection (when DB_PROVIDER=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=porizo
POSTGRES_USER=porizo
POSTGRES_PASSWORD=dev_password

# Full connection URL (alternative to individual settings)
# DATABASE_URL=postgresql://porizo:dev_password@localhost:5432/porizo

# ==============================================
# Storage Configuration (Phase 2)
# ==============================================
# STORAGE_PROVIDER: "local" (default) or "s3"
STORAGE_PROVIDER=local

# AWS S3 (when STORAGE_PROVIDER=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=porizo-storage

# LocalStack endpoint for local S3 development
# AWS_ENDPOINT=http://localhost:4566

# ==============================================
# Provider API Keys
# ==============================================
# Replicate API (for voice embedding and Suno music)
REPLICATE_API_TOKEN=your_replicate_token

# Replicate RVC model version
REPLICATE_MODEL_VERSION=0a9c7c558af4c0f20667c1bd1260ce32a2879944a0b9e44e1398660c077b1550

# Suno API (music generation)
SUNO_API_KEY=your_suno_api_key
SUNO_BASE_URL=https://api.sunoapi.org
MUSIC_PROVIDER=suno

# Seed-VC (voice conversion via Gradio)
SEED_VC_BASE_URL=http://localhost:7860

# Hugging Face token (for Seed-VC model access)
HF_TOKEN=your_hf_token

# LLM Providers (for lyrics and moderation)
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# ==============================================
# Voice Mode Configuration
# ==============================================
# DEFAULT_VOICE_MODE: "ai_voice" or "personalized"
# ai_voice: Uses Replicate RVC with pre-trained models
# personalized: Uses Seed-VC with user's enrolled voice
DEFAULT_VOICE_MODE=ai_voice

# ==============================================
# Feature Flags
# ==============================================
# LIVE_PROVIDERS: true to use real APIs, false to mock
LIVE_PROVIDERS=true

# ==============================================
# Server Configuration
# ==============================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
