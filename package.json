{
  "name": "porizo-tools",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node -r dotenv/config scripts/dev.js",
    "api": "node -r dotenv/config src/server.js",
    "worker": "node -r dotenv/config src/worker.js",
    "lint": "eslint .",
    "test": "NODE_ENV=test ALLOW_ANON_USER_ID=true ALLOW_DEVICE_TOKEN_FALLBACK=true node --test --test-concurrency=1 test/**/*.test.js",
    "eval:story": "node -r dotenv/config scripts/autoresearch-story.js --baseline-only --threshold-score=27",
    "eval:story:optimize": "node -r dotenv/config scripts/autoresearch-story.js",
    "replicate:test": "node -r dotenv/config tools/replicate-voice-test.js --input tools/replicate-input.json",
    "elevenlabs:test": "node -r dotenv/config tools/elevenlabs-music-test.js --input tools/elevenlabs-input.json",
    "preflight:subscriptions": "node tools/preflight-subscriptions-runtime.js",
    "appconfig:smoke": "node tools/verify-app-config-smoke.js",
    "migrate:files": "node -r dotenv/config scripts/migrate-files-to-s3.js",
    "migrate:files:dry-run": "node -r dotenv/config scripts/migrate-files-to-s3.js --dry-run",
    "blog:login": "node tools/blog-publish-production.js login",
    "blog:inspect": "node tools/blog-publish-production.js inspect",
    "blog:publish": "node tools/blog-publish-production.js publish",
    "verify:share-audio": "node tools/verify-share-audio-contract.js",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:shell": "docker exec -it porizo-postgres psql -U porizo -d porizo",
    "seed:status": "node -r dotenv/config scripts/dev/seed-test-state.mjs status",
    "seed:payperson": "node -r dotenv/config scripts/dev/seed-test-state.mjs payperson:on",
    "seed:payperson:off": "node -r dotenv/config scripts/dev/seed-test-state.mjs payperson:off",
    "seed:demo": "node -r dotenv/config scripts/dev/seed-test-state.mjs demo",
    "remotion:studio": "npx remotion studio marketing/remotion/src/Root.tsx --port 3100 --public-dir marketing/remotion/public",
    "remotion:render": "npx remotion render marketing/remotion/src/Root.tsx --public-dir marketing/remotion/public",
    "remotion:preview": "npx remotion preview marketing/remotion/src/Root.tsx --port 3100 --public-dir marketing/remotion/public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^1.50.1",
    "@gradio/client": "^2.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@parse/node-apn": "^7.1.0",
    "@remotion/cli": "^4.0.424",
    "@remotion/player": "^4.0.424",
    "@remotion/renderer": "^4.0.424",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "geoip-lite": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "node-html-markdown": "^2.0.0",
    "pg": "^8.16.3",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "remotion": "^4.0.424",
    "replicate": "^1.4.0",
    "resend": "^6.7.0",
    "sharp": "^0.33.5",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "agentation": "^1.3.2",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "pino-pretty": "^13.0.0"
  }
}
