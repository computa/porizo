{
  "name": "porizo-tools",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "node -r dotenv/config scripts/dev.js",
    "api": "node -r dotenv/config src/server.js",
    "worker": "node -r dotenv/config src/worker.js",
    "lint": "eslint .",
    "test": "NODE_ENV=test ALLOW_ANON_USER_ID=true ALLOW_DEVICE_TOKEN_FALLBACK=true node --test test/**/*.test.js",
    "replicate:test": "node -r dotenv/config tools/replicate-voice-test.js --input tools/replicate-input.json",
    "elevenlabs:test": "node -r dotenv/config tools/elevenlabs-music-test.js --input tools/elevenlabs-input.json",
    "migrate:files": "node -r dotenv/config scripts/migrate-files-to-s3.js",
    "migrate:files:dry-run": "node -r dotenv/config scripts/migrate-files-to-s3.js --dry-run",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:logs": "docker compose logs -f postgres",
    "db:shell": "docker exec -it porizo-postgres psql -U porizo -d porizo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^6.12.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@gradio/client": "^2.0.1",
    "@parse/node-apn": "^7.1.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "pg": "^8.16.3",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "replicate": "^1.4.0",
    "resend": "^6.7.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "agentation": "^1.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "pino-pretty": "^13.0.0"
  }
}
