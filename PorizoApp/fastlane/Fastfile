default_platform(:ios)

# Source of truth for App Store screenshots — edited here, copied into fastlane's layout at upload time.
SCREENSHOT_SOURCE = File.expand_path("../../marketing/appstore/screenshots/current", __dir__).freeze
SCREENSHOT_DEST   = File.expand_path("./screenshots/en-US", __dir__).freeze
METADATA_PATH     = File.expand_path("./metadata", __dir__).freeze
SIZES             = %w[6.9 6.5 6.3 6.1].freeze
SLIDES            = [[1, "hero"], [2, "pick"], [3, "tell"], [4, "hear"], [5, "share"]].freeze

def app_store_api_key
  key_id    = ENV.fetch("APP_STORE_CONNECT_KEY_ID")
  issuer_id = ENV.fetch("APP_STORE_CONNECT_ISSUER_ID")
  key_path  = "#{Dir.home}/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8"
  UI.user_error!("API key file not found at #{key_path}") unless File.exist?(key_path)

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_path,
    duration: 1200,
    in_house: false
  )
end

platform :ios do
  desc "Copy marketing/appstore/screenshots/current/ into fastlane/screenshots/en-US/"
  lane :prep_screenshots do
    sh "mkdir -p '#{SCREENSHOT_DEST}'"
    sh "rm -f '#{SCREENSHOT_DEST}'/*.png"
    SIZES.each do |size|
      SLIDES.each do |idx, name|
        src = "#{SCREENSHOT_SOURCE}/#{size}/porizo-#{name}.png"
        dst = "#{SCREENSHOT_DEST}/#{size.tr('.', '_')}_#{idx}_#{name}.png"
        UI.user_error!("Missing screenshot: #{src}") unless File.exist?(src)
        sh "cp '#{src}' '#{dst}'"
      end
    end
    UI.success("Copied #{SIZES.length * SLIDES.length} screenshots to #{SCREENSHOT_DEST}")
  end

  desc "Upload screenshots to App Store Connect (replaces existing)"
  lane :upload_screenshots do
    prep_screenshots

    deliver(
      api_key: app_store_api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      languages: ["en-US"],
      screenshots_path: File.expand_path("./screenshots", __dir__)
    )
  end

  desc "Upload App Store metadata only"
  lane :upload_metadata do
    deliver(
      api_key: app_store_api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      languages: ["en-US"],
      metadata_path: METADATA_PATH
    )
  end

  desc "Upload App Store metadata and screenshots together"
  lane :upload_listing_assets do
    prep_screenshots

    deliver(
      api_key: app_store_api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      languages: ["en-US"],
      metadata_path: METADATA_PATH,
      screenshots_path: File.expand_path("./screenshots", __dir__)
    )
  end

  desc "Inspect the live public Apple listing for iPhone screenshot exposure"
  lane :verify_public_listing do
    require "json"
    require "open-uri"

    bundle = CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
    url = "https://itunes.apple.com/lookup?bundleId=#{bundle}&country=us"
    result = JSON.parse(URI.open(url).read).fetch("results").first
    UI.user_error!("No public App Store result for #{bundle}") unless result

    iphone_count = result.fetch("screenshotUrls", []).length
    ipad_count = result.fetch("ipadScreenshotUrls", []).length
    UI.message("Public listing: #{iphone_count} iPhone screenshots, #{ipad_count} iPad screenshots")

    if iphone_count.zero?
      UI.important("Public iPhone screenshots are missing. Upload listing assets for the next App Store version, then re-check after approval.")
    else
      UI.success("Public iPhone screenshots are visible.")
    end
  end
end
