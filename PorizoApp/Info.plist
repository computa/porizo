<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Porizo</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>instagram-stories</string>
		<string>twitter</string>
		<string>x</string>
		<string>whatsapp</string>
		<string>facebook</string>
		<string>fb</string>
		<string>tiktok</string>
		<string>tiktokopensdk</string>
		<string>tiktoksharesdk</string>
		<string>snssdk1180</string>
		<string>snssdk1233</string>
	</array>
	<key>NSMicrophoneUsageDescription</key>
	<string>Porizo records 6-8 short voice phrases and optional voice notes to generate personalized songs.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Porizo saves your share card image to Photos so TikTok can attach it to your post.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Porizo uses speech recognition to transcribe your voice messages into text for song creation.</string>
	<key>PORIZO_API_BASE_URL</key>
	<string>$(PORIZO_API_BASE_URL)</string>
	<key>PORIZO_GOOGLE_CLIENT_ID</key>
	<string>$(PORIZO_GOOGLE_CLIENT_ID)</string>
	<key>PORIZO_GOOGLE_REDIRECT_URI</key>
	<string>$(PORIZO_GOOGLE_REDIRECT_URI)</string>
	<key>PORIZO_FACEBOOK_APP_ID</key>
	<string>$(PORIZO_FACEBOOK_APP_ID)</string>
	<key>PORIZO_FACEBOOK_REDIRECT_URI</key>
	<string>$(PORIZO_FACEBOOK_REDIRECT_URI)</string>
	<key>PORIZO_TIKTOK_CLIENT_KEY</key>
	<string>$(PORIZO_TIKTOK_CLIENT_KEY)</string>
	<key>PORIZO_TIKTOK_REDIRECT_URI</key>
	<string>$(PORIZO_TIKTOK_REDIRECT_URI)</string>
	<key>TikTokClientKey</key>
	<string>$(PORIZO_TIKTOK_CLIENT_KEY)</string>
	<key>PORIZO_ENABLE_STREAM_DIAGNOSTICS</key>
	<false/>
	<key>PORIZO_ENABLE_SUBSCRIPTIONS_UI</key>
	<true/>
	<key>PORIZO_ENABLE_GIFT_PURCHASE_UI</key>
	<true/>
	<key>FIREBASE_ANALYTICS_COLLECTION_DEACTIVATED</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>porizo</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.porizo.app</string>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>porizo-oauth</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.porizo.oauth</string>
		</dict>
		<!-- TikTok URL schemes added when client key is configured -->

	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.porizo.refresh</string>
		<string>com.porizo.render-check</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>Playfair-Variable.ttf</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
