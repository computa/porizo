<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Porizo</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Facebook Ads SDK (FBSDKCoreKit) — required for App Install attribution via Events Manager. -->
	<!-- Separate from PORIZO_FACEBOOK_APP_ID below (which is used for Facebook Login/OAuth). -->
	<!-- FacebookAppID must match the App ID shown in Meta Events Manager → Datasets → Porizo. -->
	<key>FacebookAppID</key>
	<string>$(PORIZO_FACEBOOK_ADS_APP_ID)</string>
	<key>FacebookClientToken</key>
	<string>$(PORIZO_FACEBOOK_CLIENT_TOKEN)</string>
	<key>FacebookDisplayName</key>
	<string>Porizo</string>
	<key>FacebookAutoLogAppEventsEnabled</key>
	<true/>
	<key>FacebookAdvertiserIDCollectionEnabled</key>
	<true/>
	<!-- TikTok Business SDK — required for TikTok Ads App Install attribution. -->
	<!-- Separate from PORIZO_TIKTOK_CLIENT_KEY (Login/Share OpenSDK). -->
	<!-- Get these values from TikTok Events Manager → Assets → Events → Web Events → API. -->
	<key>PORIZO_TIKTOK_BUSINESS_ACCESS_TOKEN</key>
	<string>$(PORIZO_TIKTOK_BUSINESS_ACCESS_TOKEN)</string>
	<key>PORIZO_TIKTOK_BUSINESS_APP_ID</key>
	<string>porizo.ios.app.PorizoApp</string>
	<key>PORIZO_TIKTOK_BUSINESS_TIKTOK_APP_ID</key>
	<string>$(PORIZO_TIKTOK_BUSINESS_TIKTOK_APP_ID)</string>
	<!-- AdServices.framework — Apple Search Ads attribution (iOS 14.3+). -->
	<!-- No config required in Info.plist; app calls AAAttribution.attributionToken() at launch. -->
	<!-- The attributionToken must be sent to Apple's API from your backend to get campaign data. -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>instagram-stories</string>
		<string>twitter</string>
		<string>x</string>
		<string>whatsapp</string>
		<string>facebook</string>
		<string>fb</string>
		<!-- Required by FBSDKCoreKit for app-to-Facebook handoffs and attribution -->
		<string>fbapi</string>
		<string>fb-messenger-share-api</string>
		<string>fbauth2</string>
		<string>fbshareextension</string>
		<string>tiktok</string>
		<string>tiktokopensdk</string>
		<string>tiktoksharesdk</string>
		<string>snssdk1180</string>
		<string>snssdk1233</string>
	</array>
	<key>NSMicrophoneUsageDescription</key>
	<string>Porizo records 6-8 short voice phrases and optional voice notes to generate personalized songs.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Porizo saves your share card image to Photos so TikTok can attach it to your post.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Porizo uses speech recognition to transcribe your voice messages into text for song creation.</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>Allow Porizo to measure which ads helped people discover the app so we can show more songs you'll love.</string>
	<key>PORIZO_API_BASE_URL</key>
	<string>$(PORIZO_API_BASE_URL)</string>
	<key>PORIZO_GOOGLE_CLIENT_ID</key>
	<string>$(PORIZO_GOOGLE_CLIENT_ID)</string>
	<key>PORIZO_GOOGLE_REDIRECT_URI</key>
	<string>$(PORIZO_GOOGLE_REDIRECT_URI)</string>
	<key>PORIZO_FACEBOOK_APP_ID</key>
	<string>$(PORIZO_FACEBOOK_APP_ID)</string>
	<key>PORIZO_FACEBOOK_REDIRECT_URI</key>
	<string>$(PORIZO_FACEBOOK_REDIRECT_URI)</string>
	<key>PORIZO_TIKTOK_CLIENT_KEY</key>
	<string>$(PORIZO_TIKTOK_CLIENT_KEY)</string>
	<key>PORIZO_TIKTOK_REDIRECT_URI</key>
	<string>$(PORIZO_TIKTOK_REDIRECT_URI)</string>
	<key>TikTokClientKey</key>
	<string>$(PORIZO_TIKTOK_CLIENT_KEY)</string>
	<key>PORIZO_ENABLE_STREAM_DIAGNOSTICS</key>
	<false/>
	<key>PORIZO_ENABLE_SUBSCRIPTIONS_UI</key>
	<true/>
	<key>PORIZO_ENABLE_GIFT_PURCHASE_UI</key>
	<true/>
	<key>FIREBASE_ANALYTICS_COLLECTION_DEACTIVATED</key>
	<false/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>porizo</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.porizo.app</string>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>porizo-oauth</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.porizo.oauth</string>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(PORIZO_TIKTOK_CLIENT_KEY)</string>
				<string>tt$(PORIZO_TIKTOK_CLIENT_KEY)</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.porizo.tiktok</string>
		</dict>
	</array>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>AccentColor</string>
	</dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
		<string>processing</string>
	</array>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.porizo.refresh</string>
		<string>com.porizo.render-check</string>
	</array>
	<key>UIAppFonts</key>
	<array>
		<string>Fraunces-Variable.ttf</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
