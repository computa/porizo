# Dependencies
node_modules/

# Development files
.git/
.gitignore
*.md
!README.md

# Local storage (production uses S3)
storage/
# Carve-out: artwork-library is a deployed asset (per-occasion fallback for
# free-tier songs). Bootstrapped via scripts/build-artwork-library.mjs and
# committed so it rides every container build. Must stay in sync with the
# matching carve-outs in .gitignore and .railwayignore.
!storage/artwork-library/
*.db
porizo.db

# Test files
test/
tests/
*.test.js
*.spec.js
__tests__/
coverage/

# iOS app (separate deployment)
PorizoApp/

# Admin dashboard source (separate deployment)
admin/src/
admin/node_modules/

# Development configs
.env
.env.local
.env.development
.env.test
docker-compose.yml

# IDE and OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
logs/
*.log
npm-debug.log*

# Documentation (not needed in container)
docs/
specs/

# Build artifacts
dist/
build/
.cache/
